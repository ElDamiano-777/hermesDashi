# Copy this file to .env and fill values.

# Google credentials for automatic login when no valid session exists.
SUNO_GOOGLE_EMAIL=your.email
SUNO_GOOGLE_PASSWORD=your-google-password

# Output directory for generated songs.
SUNO_OUTPUT_DIR=outputs/suno_plugin

# CDP port used for managed browser lifecycle.
SUNO_CDP_PORT=9222

# Max polling attempts while waiting for generated audio files.
SUNO_POLL_ATTEMPTS=60

# Seconds between polling attempts while waiting for generated audio files.
SUNO_POLL_INTERVAL=4.0
